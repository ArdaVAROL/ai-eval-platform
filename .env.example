APP_NAME=AI Eval Platform
API_V1_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000

# Preferred PostgreSQL configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_eval_platform

# Optional override. Use this if you want SQLite fallback locally, for example:
# DATABASE_URL=sqlite:///./backend/ai_eval_platform.db
DATABASE_URL=

OPENAI_API_KEY=

# Local Ollama provider via the OpenAI-compatible API
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
OLLAMA_API_KEY=ollama
